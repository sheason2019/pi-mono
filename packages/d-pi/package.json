{
	"name": "@sheason/d-pi",
	"version": "0.6.0-alpha.11",
	"description": "Multi-agent tree orchestrator built on pi serve mode",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sheason2019/pi-mono.git",
		"directory": "packages/d-pi"
	},
	"type": "module",
	"bin": {
		"d-pi": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./.public/d-pi-message": {
			"types": "./dist/public/d-pi-message.d.ts",
			"import": "./dist/public/d-pi-message.js"
		}
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"prebuild": "node scripts/inject-build-meta.mjs",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
		"inject-build-meta": "node scripts/inject-build-meta.mjs",
		"test": "vitest --run"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "0.78.0",
		"@earendil-works/pi-ai": "0.78.0",
		"@earendil-works/pi-tui": "0.78.0",
		"commander": "15.0.0",
		"diff": "8.0.4",
		"highlight.js": "10.7.3",
		"typebox": "1.1.38",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@types/diff": "7.0.2",
		"@types/node": "24.12.4",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	}
}
